---
import projects from '@/data/projects.json'
import Skills from './ui/Skills.astro'
import { Image } from 'astro:assets'
import { getImageFromAssets } from '@/utils'

const { condensed = false } = Astro.props
const items = condensed ? projects.slice(0, 3) : projects
---

<section
	class:list={['pb-12 scroll-m-32', Astro.props.class]}
	id="projects"
>
	<div class="space-y-8 animate">
		<div class="text-center space-y-4">
			<h2 class="section-title">Proyectos Destacados</h2>
			<p class="text-stone-600 dark:text-stone-400 max-w-2xl mx-auto">
				Proyectos de infraestructura y DevOps que demuestran mi experiencia técnica
			</p>
		</div>

		<div class="grid md:grid-cols-2 gap-6">
			{items.map((project, index) => (
				<div class="card p-6 hover:scale-[1.02] transition-transform duration-300 group">
					<div class="flex items-start gap-4">
						{project.logoUrl && (
							<div class="shrink-0">
								<Image
									src={getImageFromAssets(project.logoUrl)}
									alt={`Logo - ${project.title}`}
									class="rounded-xl shadow-md w-14 h-14 object-contain bg-white p-1"
									width={56}
									height={56}
									loading={index < 2 ? 'eager' : 'lazy'}
								/>
							</div>
						)}
						<div class="flex-1 min-w-0">
							<div class="flex items-start justify-between gap-2">
								<h3 class="font-semibold text-stone-900 dark:text-stone-100 text-lg leading-tight">
									{project.title}
								</h3>
							</div>

							{project.date && (
								<p class="text-stone-500 dark:text-stone-500 text-sm mt-1">
									<iconify-icon icon="carbon:calendar" width="14" height="14" class="inline mr-1" />
									{project.date}
								</p>
							)}

							<p class="text-stone-600 dark:text-stone-400 text-sm mt-3 leading-relaxed line-clamp-3">
								{project.description}
							</p>

							{project.skills && project.skills.length > 0 && (
								<div class="mt-4">
									<div class="flex flex-wrap gap-1.5">
										{project.skills.slice(0, 4).map((skill: string) => (
											<span class="px-2 py-0.5 text-xs rounded-full bg-stone-100 dark:bg-stone-700 text-stone-600 dark:text-stone-300">
												{skill}
											</span>
										))}
										{project.skills.length > 4 && (
											<span class="px-2 py-0.5 text-xs rounded-full bg-stone-200 dark:bg-stone-600 text-stone-500 dark:text-stone-400">
												+{project.skills.length - 4}
											</span>
										)}
									</div>
								</div>
							)}
						</div>
					</div>
				</div>
			))}
		</div>
	</div>
</section>
