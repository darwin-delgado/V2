---
import certifications from '@/data/certifications.json'

// Iconos para cada certificador
const issuerIcons: Record<string, string> = {
  'Amazon Web Services': 'logos:aws',
  'Cisco': 'logos:cisco',
  'DefensityOne': 'carbon:security'
}

const issuerColors: Record<string, string> = {
  'Amazon Web Services': 'from-orange-500 to-yellow-500',
  'Cisco': 'from-blue-600 to-cyan-500',
  'DefensityOne': 'from-red-500 to-pink-500'
}
---

<section class="pb-12 scroll-m-32" id="certifications">
  <div class="space-y-8">
    <div class="text-center space-y-4">
      <h2 class="section-title">Certificaciones</h2>
      <p class="text-stone-600 dark:text-stone-400 max-w-2xl mx-auto">
        Certificaciones profesionales que validan mis conocimientos técnicos
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-6">
      {certifications.map((cert) => (
        <div class="card p-6 hover:scale-[1.02] transition-transform duration-300">
          <div class="flex items-start gap-4">
            <div class={`p-3 rounded-xl bg-gradient-to-br ${issuerColors[cert.issuer] || 'from-stone-500 to-stone-600'} shadow-lg`}>
              <iconify-icon
                icon={issuerIcons[cert.issuer] || 'carbon:certificate'}
                width="32"
                height="32"
                class="text-white"
              />
            </div>
            <div class="flex-1">
              <h3 class="font-semibold text-stone-900 dark:text-stone-100 text-lg">
                {cert.name}
              </h3>
              <p class="text-stone-600 dark:text-stone-400 mt-1">
                {cert.issuer}
              </p>
              <p class="text-stone-500 dark:text-stone-500 text-sm mt-2">
                <iconify-icon icon="carbon:calendar" width="14" height="14" class="inline mr-1" />
                {cert.date}
              </p>
              {cert.credentialUrl && (
                <a
                  href={cert.credentialUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1 text-blue-600 dark:text-blue-400 text-sm mt-2 hover:underline"
                >
                  <iconify-icon icon="carbon:launch" width="14" height="14" />
                  Ver credencial
                </a>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
