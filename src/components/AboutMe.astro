---
import { Image } from 'astro:assets'
import me from '@/data/me.json'
import links from '@/data/links.json'
import profilePicture from '@/assets/profile-picture.webp'
import { TypewriterEffect } from '@/components/ui/typewriter-effect'

const words = me.fullName
	.split(' ')
	.map((word) => ({
		text: word
	}))
---

<section class='min-h-[90vh] flex items-center justify-center py-16 animate' id='about-me'>
	<div class='text-center space-y-8'>
		<!-- Profile Picture with glow effect -->
		<div class='flex justify-center mb-8'>
			<div class='relative'>
				<div class='absolute inset-0 bg-gradient-to-r from-blue-500 to-emerald-500 rounded-full blur-2xl opacity-30 animate-pulse'></div>
				<Image
					src={profilePicture}
					alt={me.fullName}
					class='relative rounded-full shadow-2xl object-cover ring-4 ring-stone-200 dark:ring-stone-700'
					loading='eager'
					width={180}
					height={180}
					fetchpriority='high'
				/>
			</div>
		</div>

		<!-- Greeting -->
		<p class='text-stone-500 dark:text-stone-400 text-lg font-medium tracking-wide'>
			Hola, soy
		</p>

		<!-- Name with typewriter -->
		<div class='min-h-20'>
			<TypewriterEffect client:idle words={words} />
		</div>

		<!-- Subtitle/Role -->
		<h2 class='text-2xl md:text-3xl font-medium text-stone-700 dark:text-stone-300'>
			{me.subtitle}
		</h2>

		<!-- Description -->
		<p
			set:html={me.description}
			class='text-lg text-stone-600 dark:text-stone-400 leading-relaxed max-w-3xl mx-auto px-4'
		/>

		<!-- Current Position Card -->
		<div class='card p-6 max-w-2xl mx-auto mt-8'>
			<p class='text-stone-500 dark:text-stone-400 text-sm font-medium tracking-wide mb-2'>
				Actualmente
			</p>
			<div class='flex flex-wrap gap-2 items-center justify-center'>
				<span class='text-xl font-medium text-stone-900 dark:text-stone-100' set:html={me.currentJob} />
				<span class='text-stone-500 dark:text-stone-400'>en</span>
				<span set:html={me.currentCompany} />
			</div>
		</div>

		<!-- CTA Buttons -->
		<div class='flex flex-wrap gap-4 justify-center mt-8'>
			{links.map((link: { name: string; url: string; icon: string }) => (
				<a
					href={link.url}
					target='_blank'
					rel='noopener noreferrer'
					class='group flex items-center gap-2 px-6 py-3 rounded-full bg-stone-900 dark:bg-stone-100 text-stone-100 dark:text-stone-900 font-medium hover:scale-105 transition-transform duration-300 shadow-lg hover:shadow-xl'
				>
					<iconify-icon icon={link.icon} width="20" height="20"></iconify-icon>
					{link.name}
				</a>
			))}
		</div>

		<!-- Scroll indicator -->
		<div class='pt-12 animate-bounce'>
			<iconify-icon icon="carbon:chevron-down" width="32" height="32" class="text-stone-400 dark:text-stone-500"></iconify-icon>
		</div>
	</div>
</section>

<!-- Currently Learning & Stats Section -->
<section class='py-16 animate'>
	<div class='grid md:grid-cols-2 gap-8 max-w-4xl mx-auto'>
		<!-- Currently Learning -->
		<div class='card p-6'>
			<h3 class='text-lg font-semibold text-stone-900 dark:text-stone-100 mb-4 flex items-center gap-2'>
				<iconify-icon icon="carbon:education" width="24" height="24" class="text-blue-500"></iconify-icon>
				Aprendiendo
			</h3>
			<ul class='space-y-2'>
				{me.currentlyLearning.map((item: string) => (
					<li class='flex items-center gap-2 text-stone-600 dark:text-stone-400'>
						<iconify-icon icon="carbon:arrow-right" width="16" height="16" class="text-emerald-500"></iconify-icon>
						{item}
					</li>
				))}
			</ul>
		</div>

		<!-- Location & Status -->
		<div class='card p-6'>
			<h3 class='text-lg font-semibold text-stone-900 dark:text-stone-100 mb-4 flex items-center gap-2'>
				<iconify-icon icon="carbon:location" width="24" height="24" class="text-blue-500"></iconify-icon>
				Info
			</h3>
			<ul class='space-y-3'>
				<li class='flex items-center gap-3 text-stone-600 dark:text-stone-400'>
					<iconify-icon icon="carbon:location-filled" width="20" height="20" class="text-stone-500"></iconify-icon>
					{me.location}
				</li>
				<li class='flex items-center gap-3 text-stone-600 dark:text-stone-400'>
					<iconify-icon icon="carbon:time" width="20" height="20" class="text-stone-500"></iconify-icon>
					{me.timezone}
				</li>
				<li class='flex items-center gap-3'>
					<span class='relative flex h-3 w-3'>
						<span class='animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75'></span>
						<span class='relative inline-flex rounded-full h-3 w-3 bg-emerald-500'></span>
					</span>
					<span class='text-emerald-600 dark:text-emerald-400 font-medium'>{me.status}</span>
				</li>
			</ul>
		</div>
	</div>
</section>
